# Copy this file to `.env` and fill in the real value.
# `.env` is gitignored and must NEVER be committed.

# Todoist API token (Todoist unified API v1). Get it from Todoist > Settings > Integrations > Developer.
TODOIST_API_TOKEN=your_todoist_api_token_here

# Optional: absolute path to the SQLite database file.
# Defaults to ./data/todoist-points.db when unset (fine for local dev).
# In Docker, docker-compose.yml sets DB_PATH=/data/todoist-points.db (a mounted
# volume) — you don't need to set it here for the compose deployment.
#DB_PATH=/data/todoist-points.db

# --- App-level shared-password sign-in gate (src/middleware.ts) ---
# Set APP_PASSWORD to turn the gate ON: every request without a valid signed
# session cookie is redirected to /login (or 401'd for /api/*). Leave it
# UNSET/EMPTY to keep the gate OFF (app behaves as today — e.g. while still
# behind Cloudflare Access). Cutover = set both of these on the box, then drop
# the CF_ACCESS_* vars.
#   APP_PASSWORD   — the shared secret everyone types at /login.
#   SESSION_SECRET — random key that signs the ~30-day session cookie. Generate
#                    a strong one, e.g.  openssl rand -hex 32
# Both are read from process.env and never hardcoded. Keep them out of git.
APP_PASSWORD=your_shared_login_password_here
SESSION_SECRET=your_random_session_signing_secret_here

# Cloudflare Access JWT verification (LEGACY — used before the password-gate
# cutover; leave unset for local dev and after cutover). When APP_PASSWORD is
# set, the password gate takes precedence and this block is skipped.
# CF_ACCESS_AUD is the Access application's Audience (AUD) tag for
# todoist-points.graham-williams.com, copied from the Cloudflare Zero Trust
# dashboard or API. Required by docker-compose.yml (the team domain and
# APP_HOST are hardcoded there).
CF_ACCESS_AUD=your_cloudflare_access_app_aud_tag_here
