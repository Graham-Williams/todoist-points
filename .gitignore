# dependencies
node_modules/
.pnp
.pnp.js

# next.js
.next/
out/
build/
dist/

# secrets — NEVER commit these (catch-all; only the placeholder examples are tracked)
.env*
!.env.example
# self-hosted backup config: the real .env.backup is ignored by .env* above;
# only the placeholder example is committed (it contains no secrets either).
!.env.backup.example

# database / local data — NEVER commit (contains personal task + points data)
*.db
*.sqlite
*.sqlite3
data/
*.db-journal
*.db-wal
*.db-shm
# backup runtime state (checksums, last-push timestamp) on the host
.backup-state/

# misc
.DS_Store
*.log
npm-debug.log*
.vercel
coverage/
